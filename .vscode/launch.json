{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DirectoryService.Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/backend/DirectoryService/src/DirectoryService.Web/bin/Debug/net10.0/DirectoryService.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/DirectoryService/src/DirectoryService.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
