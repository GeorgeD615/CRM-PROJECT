is_global = true

# Все правила категории security — ошибки
dotnet_analyzer_diagnostic.category-security.severity = error

# CA2007: ConfigureAwait — не нужен в ASP.NET Core (фреймворк сам управляет контекстом)
dotnet_diagnostic.CA2007.severity = none

# CA1062: проверка null-аргументов — nullable reference types делают это за нас
dotnet_diagnostic.CA1062.severity = none

# CA1812: не инстанцированные классы — ложные срабатывания на DI-классах
dotnet_diagnostic.CA1812.severity = none

# CA1034: вложенные типы — в vertical slice один файл содержит несколько типов (Command/Handler)
dotnet_diagnostic.CA1034.severity = none

# CA1515: internal-типы — MVC-контроллеры обязаны быть public для discovery фреймворком
dotnet_diagnostic.CA1515.severity = none

# CA1308: нормализация строк в верхний регистр — slug и path канонически в нижнем регистре
dotnet_diagnostic.CA1308.severity = none

# CA1032, RCS1194: стандартные конструкторы исключений — бизнес-исключения создаются
# только с обязательным контекстом, конструкторы без сообщения не нужны
dotnet_diagnostic.CA1032.severity = none
dotnet_diagnostic.RCS1194.severity = none

# CA1724: конфликт имени типа с пространством имён — соглашение проекта:
# в каждом слое класс DependencyInjection с методом регистрации сервисов
dotnet_diagnostic.CA1724.severity = none

# CA1861: константные массивы в аргументах — срабатывает на сгенерированных EF-миграциях
dotnet_diagnostic.CA1861.severity = none

# MA0004: ConfigureAwait — не нужен в ASP.NET Core
dotnet_diagnostic.MA0004.severity = none

# MA0048: имя файла = имя типа — конфликт с vertical slice (несколько типов в файле)
dotnet_diagnostic.MA0048.severity = none

# MA0051: длина метода — обработчики use case намеренно длинные
dotnet_diagnostic.MA0051.severity = none

# MA0053: sealed классы — слишком агрессивно для DDD-сущностей
dotnet_diagnostic.MA0053.severity = none

# RCS1090: ConfigureAwait — не нужен в ASP.NET Core
dotnet_diagnostic.RCS1090.severity = none

# AsyncFixer01: убрать async/await — меняет поведение исключений в middleware
dotnet_diagnostic.AsyncFixer01.severity = none

# S1135: TODO/FIXME комментарии — маяки, не баги
dotnet_diagnostic.S1135.severity = none

# S1144: неиспользуемые private члены — ложные срабатывания на EF shadow props
dotnet_diagnostic.S1144.severity = none

# S1186: пустые методы — сгенерированные EF-миграции с пустыми Up/Down
# (изменения внутри jsonb-колонки не меняют схему, миграция только синхронизирует снапшот)
dotnet_diagnostic.S1186.severity = none

# CA1848, CA1873: делегаты LoggerMessage и защита от вычисления аргументов —
# микрооптимизации логгирования, не оправданы на текущем этапе
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA1873.severity = none

# Правила строже, чем по умолчанию:
dotnet_diagnostic.S1125.severity = error  # Redundant Boolean literal
dotnet_diagnostic.S6673.severity = error  # Serilog template placeholder order
dotnet_diagnostic.S108.severity  = error  # Пустой catch-блок без комментария

# Разрешение на использование ключевого слова Error
dotnet_diagnostic.CA1716.severity = none

# Отлов исключение в ExceptionMidleware
dotnet_diagnostic.CA1031.severity = none